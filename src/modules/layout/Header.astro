---
import { uiText } from "@modules/i18n/strings";
import { getLocaleFromPathname } from "@modules/i18n/util";
import { i18n, type Locale } from "@/modules/i18n/types";

interface Props {
  lang?: string;
}

const { lang } = Astro.props;
const locale: Locale = (lang as Locale) ?? getLocaleFromPathname(Astro.url.pathname) ?? i18n.defaultLocale;
const text = uiText[locale];
const isPortfolioPage = Astro.url.pathname === "/portfolio/";
---

<header class="relative mb-24 flex w-full items-center justify-center">
  <div>
    <h1 class="leading-none font-semibold">
      <a class="inline-flex items-center gap-1" href="/">
        <img
          aria-hidden="true"
          alt=""
          src="/icon.png"
          width="18"
          height="18"
          class="opacity-80 dark:invert"
        />
        {text.headerTitle}
      </a>
    </h1>
  </div>

  {isPortfolioPage && (
    <a
      href="/"
      class="absolute top-1/2 left-0 -translate-y-1/2 rounded-sm p-2 transition hover:bg-gray-400/10 hover:opacity-90"
      aria-label={text.backToList}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    </a>
  )}
</header>
