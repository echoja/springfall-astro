---
import type { Category } from "@modules/category";
import { getCategoryLabel } from "@modules/category";
import dayjs from "dayjs";
import { i18n, type Locale } from "@/modules/i18n/types";
import { uiText } from "@modules/i18n/strings";

interface Props {
  title: string;
  createdAt: string;
  summary?: string;
  category?: Category;
  locale?: Locale;
  languageLinks?: Array<{ locale: string; href: string }>;
}

const {
  title,
  createdAt,
  summary,
  category,
  locale = i18n.defaultLocale,
  languageLinks = [],
} = Astro.props;

const text = uiText[locale];
---

<header class="mb-24">
  <div class="mb-3 text-xs font-medium text-gray-500 dark:text-gray-400">
    <time datetime={createdAt}>{dayjs(createdAt).format("YYYY.MM")}</time>
    {category && (
      <>
        <span class="opacity-50"> | </span>
        <span>{getCategoryLabel(category, locale)}</span>
      </>
    )}
  </div>
  <h1 class="mb-2 text-4xl font-extrabold break-keep dark:text-gray-100">
    {title}
  </h1>
  {summary && (
    <p class="text-sm break-keep">{summary}</p>
  )}
  {languageLinks.length >= 2 && (
    <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-gray-600 dark:text-gray-400">
      <span class="opacity-70">{text.availableLabel}</span>
      {languageLinks.map((l) =>
        l.locale === locale ? (
          <span
            aria-current="true"
            class="font-semibold text-gray-900 dark:text-gray-100"
          >
            {l.locale}
          </span>
        ) : (
          <a
            href={l.href}
            class="underline decoration-dotted hover:opacity-80"
          >
            {l.locale}
          </a>
        ),
      )}
    </div>
  )}
</header>
