---
import { Picture } from "astro:assets";
import { twMerge } from "tailwind-merge";
import style from "./style.module.css";

interface Props {
  src?: string;
  img?: ImageMetadata;
  caption?: string;
  alt?: string;
  width?: number;
  noShadow?: boolean;
  border?: boolean;
}

const { src, img, caption, alt = "", width, noShadow, border } = Astro.props;
const hasSlot = Astro.slots.has("default");
const imgClass = twMerge(
  style.image,
  noShadow && style["no-shadow"],
  border && style["image-border"],
);
const usePicture = img && img.format !== "gif" && img.format !== "svg";
---

<figure class={style["image-figure"]}>
  {usePicture ? (
    <Picture
      src={img}
      alt={alt}
      formats={["avif", "webp"]}
      widths={[720, 1408]}
      class={imgClass}
      loading="lazy"
    />
  ) : (
    <img
      class={imgClass}
      width={width}
      src={img?.src ?? src}
      alt={alt}
      loading="lazy"
    />
  )}
  {hasSlot ? (
    <figcaption class={style["image-caption"]}><slot /></figcaption>
  ) : caption ? (
    <figcaption class={style["image-caption"]}>{caption}</figcaption>
  ) : null}
</figure>
