---
import { twMerge } from "tailwind-merge";
import style from "./style.module.css";

interface Props {
  src?: string;
  img?: ImageMetadata;
  caption?: string;
  alt: string;
  width?: number;
  noShadow?: boolean;
  border?: boolean;
}

const { src, img, caption, alt, width, noShadow, border } = Astro.props;
const imgSrc = img?.src ?? src;
const hasSlot = Astro.slots.has("default");
---

<figure class={style["image-figure"]}>
  <img
    class={twMerge(
      style.image,
      noShadow && style["no-shadow"],
      border && style["image-border"],
    )}
    width={width}
    src={imgSrc}
    alt={alt}
    loading="lazy"
  />
  {hasSlot ? (
    <figcaption class={style["image-caption"]}><slot /></figcaption>
  ) : caption ? (
    <figcaption class={style["image-caption"]}>{caption}</figcaption>
  ) : null}
</figure>
