---
import { projects } from "@modules/portfolio/data";
import { experiences } from "@modules/portfolio/experiences";
---

<div>
  <button
    id="portfolio-pdf-btn"
    class="no-print fixed top-16 right-4 z-10 flex items-center gap-2 rounded-lg bg-gray-900 px-3 py-2 text-xs font-medium text-white shadow-lg transition-colors hover:bg-gray-800 sm:top-20 sm:right-6 sm:px-4 sm:text-sm"
  >
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
      />
    </svg>
    <span class="hidden sm:inline">PDF 다운로드</span>
    <span class="sm:hidden">PDF</span>
  </button>

  <div id="portfolio-content" class="bg-white text-gray-900">
    <header class="mb-6 border-b-2 border-gray-900 pb-4 sm:mb-8 sm:pb-6">
      <h1 class="print-title mb-3 text-2xl font-bold sm:text-3xl lg:text-4xl">
        포트폴리오
      </h1>
      <p class="print-subtitle text-base leading-relaxed text-gray-700 sm:text-lg">
        사용자 경험과 성능을 중시하는 프로덕트 엔지니어입니다.
      </p>
    </header>

    <section class="mb-8 sm:mb-10">
      <h2 class="print-heading mb-4 border-b-2 border-gray-300 pb-2 text-xl font-bold sm:mb-5 sm:text-2xl">
        경력
      </h2>
      <div class="space-y-4 sm:space-y-5">
        {experiences.map((exp) => (
          <div class="pb-4 sm:pb-5">
            <div class="mb-2 flex flex-col sm:flex-row sm:items-baseline sm:justify-between">
              <div>
                <h3 class="print-subheading text-base font-bold sm:text-lg">
                  {exp.company}
                </h3>
                <p class="print-body text-sm text-gray-600 sm:text-base">
                  {exp.role}
                </p>
              </div>
              <span class="print-body mt-1 text-sm text-gray-600 sm:mt-0 sm:text-base">
                {exp.period}
              </span>
            </div>
            {exp.details && (
              <ul class="print-body mt-3 ml-5 list-disc space-y-1 text-sm text-gray-700 sm:text-base">
                {exp.details.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </section>

    <section class="mb-8 sm:mb-10">
      <h2 class="print-heading mb-4 border-b-2 border-gray-300 pb-2 text-xl font-bold sm:mb-5 sm:text-2xl">
        프로젝트
      </h2>
      <div class="space-y-4 sm:space-y-5">
        {projects.map((project) => (
          <div class="border-b border-gray-200 pb-4 last:border-0 sm:pb-5">
            <div class="mb-2 flex flex-col sm:flex-row sm:items-baseline sm:justify-between">
              <h3 class="print-subheading text-base font-bold sm:text-lg">
                {project.title}
              </h3>
              {project.period && (
                <span class="print-body mt-1 text-sm text-gray-600 sm:mt-0 sm:text-base">
                  {project.period}
                </span>
              )}
            </div>
            <p class="print-body mb-3 text-sm leading-relaxed text-gray-700 sm:text-base">
              {project.description}
            </p>
            {project.highlights && project.highlights.length > 0 && (
              <ul class="print-body mb-3 ml-5 list-disc space-y-1 text-sm text-gray-600 sm:text-base">
                {project.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            )}
            {project.tags && project.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <span class="print-small rounded border border-gray-400 px-2 py-1 text-xs sm:px-2.5 sm:text-sm">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <footer class="print-body no-print border-t-2 border-gray-300 pt-4 text-sm text-gray-600 sm:pt-5 sm:text-base">
      <p>협업이나 제안이 있다면 연락 주세요.</p>
    </footer>
  </div>
</div>

<script>
  document
    .getElementById("portfolio-pdf-btn")
    ?.addEventListener("click", () => window.print());
</script>
