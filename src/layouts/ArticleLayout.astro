---
import BaseLayout from "./BaseLayout.astro";
import ArticlePageHeader from "@modules/layout/ArticlePageHeader.astro";
import ArticleHeader from "@modules/article/ArticleHeader.astro";
import FloatingToc from "@modules/article/FloatingToc";
import Giscus from "@modules/giscus";
import { uiText } from "@modules/i18n/strings";
import { i18n, type Locale } from "@/modules/i18n/types";
import type { Category } from "@modules/category";

interface Props {
  title: string;
  description?: string;
  createdAt: string;
  updatedAt?: string;
  category?: Category;
  locale?: Locale;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
  canonicalUrl?: string;
  alternates?: Array<{ locale: string; href: string }>;
  languageLinks?: Array<{ locale: string; href: string }>;
}

const {
  title,
  description,
  createdAt,
  category,
  locale = i18n.defaultLocale,
  ogImage,
  jsonLd,
  canonicalUrl,
  alternates,
  languageLinks = [],
} = Astro.props;

const text = uiText[locale];
const tocLabels = {
  tocTitle: text.tocTitle,
  tocFloatingLabel: text.tocFloatingLabel,
  tocCloseLabel: text.tocCloseLabel,
};
---

<BaseLayout
  title={title}
  description={description}
  lang={locale}
  ogImage={ogImage}
  ogType="article"
  jsonLd={jsonLd}
  canonicalUrl={canonicalUrl}
  alternates={alternates}
>
  <ArticlePageHeader lang={locale} />
  <main class="relative">
    <article class="mb-20 lg:-translate-x-38 animate-fade-in">
      <ArticleHeader
        title={title}
        createdAt={createdAt}
        summary={description}
        category={category}
        locale={locale}
        languageLinks={languageLinks}
      />
      <slot />
    </article>
    <FloatingToc client:idle labels={tocLabels} />
  </main>
  <Giscus client:visible locale={locale} className="mt-8" />
</BaseLayout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out;
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('.code-copy-btn') as HTMLButtonElement | null;
    if (!btn) return;
    const code = btn.dataset.code;
    if (!code) return;
    navigator.clipboard.writeText(code);
    const svg = btn.querySelector('svg')!;
    // Switch to check icon
    svg.innerHTML = '<polyline points="20 6 9 17 4 12" />';
    setTimeout(() => {
      svg.innerHTML =
        '<rect width="14" height="14" x="8" y="8" rx="2" ry="2" /><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />';
    }, 1200);
  });
</script>
